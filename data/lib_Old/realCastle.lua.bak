				Real Castle Event
	Desenvolvido por Vítor Bertolucci (Killua), modificado por Dwarfer

]]

realCastle = {
	
    open_storage = 100005,
    guild_storage = 100006,
    date_storages = {100007,100008,100009},
    frompos = {x = 982, y = 742, z = 4},
    topos = {x = 1032, y = 792, z = 7},
    
    -- by dwarfer
    days = {
        ["Monday"] = {"20:59", "21:59"}, 
        ["Tuesday"] = {"20:59", "21:59"},
        ["Wednesday"] = {"20:59", "21:59"},
        ["Thursday"] = {"20:59", "21:59"},
        ["Friday"] = {"20:59", "21:59"},
        ["Saturday"] = {"00:25", "00:26"},
        ["Sunday"] = {"20:59", "21:59"}
    },
    accessDuration = {20, "hour"}, -- tempo de duraçăo do acesso
    invitationInterval = {10, "sec"}, -- exausthed para invitar players no scroll
    storages = { -- só modifique os storages se necessário
        accessTime = 100010,
        inviteInterval = 100011,
        invited = 100012,
        running = 100013
    }


}

realCastle.removePlayers = function()
	local first_cave = getPlayersInArea({x = 2829, y = 7, z = 7},{x = 3118, y = 467, z = 7})
	
	local castle_area = getPlayersInArea(realCastle.frompos,realCastle.topos)
	if first_cave then
		for _, pid in pairs(first_cave) do
			doTeleportThing(pid,getTownTemplePosition(1))
			doPlayerPopupFYI(pid,"O domínio de sua guild sob o castelo acabou e uma nova batalha está se iniciando.")
		end
	end
	
end

realCastle.open = function()
	setGlobalStorageValue(realCastle.open_storage,1)
	setGlobalStorageValue(realCastle.guild_storage,-1)
   setGlobalStorageValue(realCastle.storages.running, 1)
	-- realCastle.removePlayers()
	OpenWallCok()
	shutdowncastle()
	db.executeQuery("UPDATE `guilds` SET `real_castle` = 0;")
	doBroadcastMessage("[RETRO-CASTLE] O Castelo foi aberto, o duelo pelo poder termina as 21:59, boa sorte para toda as guilds participantes!", 21)
end

realCastle.close = function()
	setGlobalStorageValue(realCastle.open_storage,-1)
	local players = getPlayersInArea(realCastle.frompos, realCastle.topos)
	if players then
		for _, pid in pairs(players) do
			doTeleportThing(pid,getTownTemplePosition(1))
		end
	end
	if getGlobalStorageValue(realCastle.guild_storage) == -1 then
		doBroadcastMessage("[RETRO-CASTLE] A batalhar terminou e nenhuma guild conseguiu dominar o castelo!")
	else
		doBroadcastMessage("[RETRO-CASTLE] A batalha terminou e a guild vencedora foi "..getGuildNameByID(getGlobalStorageValue(realCastle.guild_storage)).."! Todos os jogadores dessa guild agora podem aproveitar o bonus de 10% de experięncia ate as 20:00!")
      setGlobalStorageValue(realCastle.storages.accessTime, mathtime(realCastle.accessDuration) + os.time())
	end
	local func = db.query or db.executeQuery
		db.executeQuery("UPDATE `guilds` SET `real_castle` = 1 WHERE `guilds`.`id` = "..getGlobalStorageValue(realCastle.guild_storage)..";")
	print("Adicionando a guild")
	setGlobalStorageValue(realCastle.storages.running, -1)
	FecharWallCok()
	doSaveServer()
end

realCastle.broadcast = function(message)
	local players = getPlayersInArea(realCastle.frompos, realCastle.topos)
	if players then
		for _, pid in pairs(players) do
			doPlayerSendTextMessage(pid,MESSAGE_STATUS_WARNING,message)
		end
	end
end

realCastle.domain = function(cid)
	local guild_id = getPlayerGuildId(cid)
	setGlobalStorageValue(realCastle.guild_storage,guild_id)
	realCastle.broadcast("[RETRO-CASTLE] O jogador "..getPlayerName(cid).." da guild "..getPlayerGuildName(cid).." dominou o castelo!")
end

realCastle.isDominating = function(cid)
	local guild_id = getPlayerGuildId(cid)
	return guild_id == getGlobalStorageValue(realCastle.guild_storage)
end

realCastle.isOpen = function()
	return getGlobalStorageValue(realCastle.open_storage) == 1
end

--- Config by Dwarfer
realCastle.isRunning = function()
    return getGlobalStorageValue(realCastle.storages.running) ~= -1 
end

realCastle.checkFinishAccess = function()
	local function isCastleOwner(cid)
		if getGlobalStorageValue(realCastle.guild_storage) == getPlayerGuildId(cid) then
			return true
		end
		return false
	end
	local function isWithDoubleBonus(cid)
		local bonus = getPlayerStorageValue(cid, 23512)
		if (bonus - os.time()) > 0 then
			return true
		end
		return false
	end
	local function getExpRate(cid)
		local rate = 1
		local premium_rate = 0.0
		local castle_rate = 0.10
		local double_rate = rate * 2
		if not isPremium(cid) then
			premium_rate = 0
		end
		if not isCastleOwner(cid) then
			castle_rate = 0
		end
		if not isWithDoubleBonus(cid) then
			double_rate = 0
		end
		local playerRate = rate + premium_rate + castle_rate + double_rate
		return playerRate
	end	
    if (not realCastle.isOpen()) and (not realCastle.isRunning()) then
        if getGlobalStorageValue(realCastle.storages.accessTime) ~= -1 and getGlobalStorageValue(realCastle.storages.accessTime) <= os.time() then
			local oldOwners = getGlobalStorageValue(realCastle.guild_storage)
			db.executeQuery("UPDATE `guilds` SET `real_castle` = 0 WHERE `guilds`.`id` = "..getGlobalStorageValue(realCastle.guild_storage)..";")
			setGlobalStorageValue(realCastle.guild_storage, -1)
			print("old owners >> "..oldOwners)
			for _, cid in pairs(getPlayersOnline()) do
				if getPlayerGuildId(cid) == oldOwners then			
					print("1 player rate > "..getPlayerRates(cid)[9].." getExpRate > "..getExpRate(cid))
					doPlayerSetExperienceRate(cid, getExpRate(cid))
					print("2 player rate > "..getPlayerRates(cid)[9].." getExpRate > "..getExpRate(cid))
				end
			end
            doBroadcastMessage("[RETRO-CASTLE] O Bonus de 10% de experiencia da guild vencedora do ultimo Castle 48horas acabou de acabar!", MESSAGE_STATUS_CONSOLE_RED)
			setGlobalStorageValue(realCastle.storages.accessTime, -1)
            
			print("owners >> "..getGlobalStorageValue(realCastle.guild_storage))
            realCastle.removePlayers()
        end
    end
end
